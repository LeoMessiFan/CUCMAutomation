# ─────────────────────────────────────────────────────────
# UC Automation Portal — Environment Variables Template
# Copy this file to .env and fill in your values.
# NEVER commit .env to Git.
# ─────────────────────────────────────────────────────────

# Flask secret key — use a long random string
FLASK_SECRET_KEY=change_this_to_a_long_random_secret_key

# Cisco CUCM AXL credentials
AXL_USERNAME=axl-test
AXL_PASSWORD=your_axl_password_here
AXL_FQDN=cucm-hostname.yourdomain.com

# Optional: secondary CUCM (subscriber)
# AXL_FQDN2=cucm-subscriber.yourdomain.com

# Path to WSDL file (relative to project root)
WSDL_PATH=schema/AXLAPI.wsdl

# Flask environment
FLASK_ENV=production

# Host and port for Gunicorn
HOST=0.0.0.0
PORT=5000
